# Knowledge Island — 环境变量模板
# 复制为 .env 并按需修改；.env 是本机配置，不应提交到仓库
#
# 优先级：OS 环境变量 > appdata/.env > 项目根 .env > 代码默认值

# ── 知识库 ────────────────────────────────────────────────
# 知识库根目录（支持 ~ 展开）
# RAG_KB_ROOT=~/KnowledgeIslandKB

# ── 运行时 ────────────────────────────────────────────────
# SQLite / ChromaDB / 日志的存放根目录
# RAG_RUNTIME_DIR=./runtime

# ── Ollama ────────────────────────────────────────────────
# RAG_OLLAMA_HOST=http://localhost:11434
# RAG_OLLAMA_MODEL=qwen2.5:7b
# RAG_EMBEDDING_MODEL=nomic-embed-text
# RAG_EMBEDDING_DIM=768
# Web MVP 可选：OpenAI-compatible Embeddings。服务需支持 /embeddings。
# RAG_EMBED_PROVIDER=api
# RAG_EMBED_API_BASE=https://api.openai.com/v1
# RAG_EMBED_API_MODEL=text-embedding-3-small
# RAG_EMBED_API_KEY=sk-xxx

# ── 检索 ─────────────────────────────────────────────────
# RAG_RETRIEVER_KIND=vector          # vector | keyword
# RAG_CHUNK_SIZE=512
# RAG_CHUNK_OVERLAP=64
# RAG_TOP_K=8
# 可选：启用 Qdrant local mode 替代 SQLite 向量全扫描；默认不启用。
# RAG_VECTOR_STORE_PROVIDER=qdrant
# RAG_QDRANT_PATH=./runtime/qdrant
# RAG_QDRANT_COLLECTION=knowledge_island_chunks
# RAG_QDRANT_VECTOR_SIZE=96
# 可选 Cross-Encoder Reranker；需要额外安装 sentence-transformers。
# RAG_RERANKER_ENABLED=false
# RAG_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ── LLM 生成 ─────────────────────────────────────────────
# RAG_LLM_TEMPERATURE=0.7
# RAG_LLM_MAX_TOKENS=2048
# RAG_LLM_PROVIDER=api
# RAG_LLM_API_BASE=https://api.deepseek.com/v1
# RAG_LLM_API_MODEL=deepseek-chat
# RAG_LLM_API_KEY=sk-xxx
