# Copy to .env or export values before starting Docker Compose.
# Do not commit real API keys.

# Web
KI_PORT=8765
KNOWLEDGE_ISLAND_WORKSPACE=./docker-workspace

# LLM
RAG_LLM_PROVIDER=api
RAG_LLM_API_BASE=https://api.deepseek.com/v1
RAG_LLM_API_MODEL=deepseek-chat
RAG_LLM_API_KEY=
DEEPSEEK_API_KEY=

# Embedding
RAG_EMBED_PROVIDER=
RAG_EMBED_API_BASE=
RAG_EMBED_API_MODEL=
RAG_EMBED_API_KEY=

# Auth
RAG_AUTH_ENABLED=false
RAG_AUTH_API_KEY=
RAG_AUTH_JWT_SECRET=
