{
  "name": "knowledge-island-frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5173",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "test": "npm run test:unit",
    "test:unit": "vitest run --config frontend/vite.config.js",
    "e2e:install": "playwright install chromium",
    "test:e2e": "npm run build && playwright test",
    "sidecar:build": "powershell -ExecutionPolicy Bypass -File scripts/build-backend-sidecar.ps1",
    "sidecar:build:unix": "bash scripts/build-backend-sidecar.sh",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:windows": "npm run sidecar:build && tauri build",
    "tauri:build:macos": "npm run sidecar:build:unix && tauri build --bundles dmg",
    "tauri:build:linux": "npm run sidecar:build:unix && tauri build --bundles appimage"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^6.0.2",
    "pinia": "^3.0.4",
    "vite": "^7.3.6",
    "vue": "^3.5.24"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tauri-apps/cli": "^2.11.3",
    "@vue/test-utils": "^2.4.11",
    "jsdom": "^29.1.1",
    "vitest": "^4.1.9"
  }
}
