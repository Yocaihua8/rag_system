# Career Assistant — 环境变量模板
# 复制为 .env 并按需修改；.env 是本机配置，不应提交到仓库
#
# 优先级：OS 环境变量 > appdata/.env > 项目根 .env > 代码默认值

# ── 知识库 ────────────────────────────────────────────────
# 知识库根目录（支持 ~ 展开）
# RAG_KB_ROOT=~/CareerAssistantKB

# ── 运行时 ────────────────────────────────────────────────
# SQLite / ChromaDB / 日志的存放根目录
# RAG_RUNTIME_DIR=./runtime

# ── Ollama ────────────────────────────────────────────────
# RAG_OLLAMA_HOST=http://localhost:11434
# RAG_OLLAMA_MODEL=qwen2.5:7b
# RAG_EMBEDDING_MODEL=nomic-embed-text
# RAG_EMBEDDING_DIM=768

# ── 检索 ─────────────────────────────────────────────────
# RAG_RETRIEVER_KIND=vector          # vector | keyword
# RAG_CHUNK_SIZE=512
# RAG_CHUNK_OVERLAP=64
# RAG_TOP_K=8

# ── LLM 生成 ─────────────────────────────────────────────
# RAG_LLM_TEMPERATURE=0.7
# RAG_LLM_MAX_TOKENS=2048
