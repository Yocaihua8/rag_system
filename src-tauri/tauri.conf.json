{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Knowledge Island",
  "version": "0.1.0",
  "identifier": "local.knowledge-island.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../backend/static_dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Knowledge Island",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "externalBin": ["binaries/knowledge-island-backend"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
